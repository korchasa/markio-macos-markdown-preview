<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleExecutable</key>
    <string>Markio</string>
    <key>CFBundleIdentifier</key>
    <string>dev.markio.app</string>
    <key>CFBundleName</key>
    <string>Markio</string>
    <key>CFBundleDisplayName</key>
    <string>Markio</string>
    <!-- App Store icon comes from the compiled asset catalog (Assets.car) via
         CFBundleIconName. No CFBundleIconFile: the loose AppIcon.icns actool
         emits caps at 256×256, and when it is referenced App Store ingest picks
         it over the catalog's 1024×1024 marketing icon, leaving the listing
         icon blank. macOS 14+ resolves the Dock icon from the catalog too. -->
    <key>CFBundleIconName</key>
    <string>AppIcon</string>
    <!-- English only. The app's own menu items (Find…, Table of Contents,
         Compare Side by Side…) ship untranslated, so declaring extra locales
         makes AppKit render ITS standard items (Файл, Правка…) in the system
         language while ours stay English — a mixed-language menu bar. One
         declared locale keeps the whole UI in one language. -->
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleLocalizations</key>
    <array>
        <string>en</string>
    </array>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>8</string>
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>
    <!-- Required by App Store validation (error 90242); must match the primary
         category configured in App Store Connect. -->
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.productivity</string>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <!-- Read-only Markdown viewer: declare .md/.markdown so Finder "Open With"
         and `open -a Markio file.md` route to us. -->
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeName</key>
            <string>Markdown Document</string>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>LSHandlerRank</key>
            <string>Alternate</string>
            <key>CFBundleTypeExtensions</key>
            <array>
                <string>md</string>
                <string>markdown</string>
            </array>
            <key>LSItemContentTypes</key>
            <array>
                <string>net.daringfireball.markdown</string>
                <string>public.plain-text</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
