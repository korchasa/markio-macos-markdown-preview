<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Quick Look preview extension. App extensions must run sandboxed to be
      loaded at all; Quick Look grants the extension read access to the
      previewed file itself. Rendering assets ship inside the .appex.

      network.client is REQUIRED despite the extension being fully offline:
      without it the sandboxed WKWebView never launches its WebContent helper
      ("WebProcess with PID 0" in the log) and render() hangs forever — Finder
      shows an infinite spinner (reproduced 2026-07-14 on the wave-1 build).
      Same failure mode as the host app (see Markio.entitlements). The host
      cancels every post-load navigation, so no network is ever used.

      Ad-hoc signing with this file is done by `make app` so the extension is
      locally runnable; distribution signing is app-store-factory's job.
    -->
    <key>com.apple.security.app-sandbox</key>
    <true/>
    <key>com.apple.security.files.user-selected.read-only</key>
    <true/>
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
