<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Quick Look preview extension. App extensions must run sandboxed to be
      loaded at all; Quick Look grants the extension read access to the
      previewed file itself. Rendering assets ship inside the .appex.

      No network.client here: Quick Look ignores it (documented in
      sbarex/QLTest), and WKWebView-based QL extensions demonstrably run
      without it — unlike the host app, whose WebContent process needed it
      (see Markio.entitlements). If a factory-signed build ever shows a blank
      preview, revisit this (recorded in the task's Follow-ups).

      Ad-hoc signing with this file is done by `make app` so the extension is
      locally runnable; distribution signing is app-store-factory's job.
    -->
    <key>com.apple.security.app-sandbox</key>
    <true/>
    <key>com.apple.security.files.user-selected.read-only</key>
    <true/>
</dict>
</plist>
